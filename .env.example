# ─────────────────────────────────────────────
#  CLI Browser Chat — environment configuration
#  Copy this file to .env and adjust as needed.
# ─────────────────────────────────────────────

# Directory that contains the compiled front-end (index.html, assets, …)
STATIC_DIR=dist

# SQLite database path (relative to server.py or absolute)
DB_FILE=chat.db

# HTTP server (serves the SPA)
HTTP_HOST=127.0.0.1
HTTP_PORT=8080

# WebSocket server
WS_HOST=127.0.0.1
WS_PORT=8765

# Max message length in characters
MAX_MSG_LEN=4000

# Max WebSocket frame size in bytes
MAX_WS_SIZE=65536

# How many global messages to send on initial load
GLOBAL_HIST=200

# bcrypt work factor (higher = slower hashing, more secure; 12 is a good default)
BCRYPT_ROUNDS=12

# Rate limiting: max auth attempts per IP within the window (seconds)
RATE_LIMIT_ATTEMPTS=10
RATE_LIMIT_WINDOW=60

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
